			"types": "./dist/index.d.ts",
			"require": "./dist/index.js"
		}
	},
	"dependencies": {
		"@react-email/components": "^0.5.7",
		"@react-email/render": "^1.4.0",
		"express": "^5.1.0",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"tsx": "^4.20.4"
	},
	"devDependencies": {
		"@beatros/typescript-config": "workspace:*",
		"@types/express": "^5.0.3",
		"@types/node": "^20.19.11",
		"@types/react": "^19.1.11",
		"@types/react-dom": "^19.1.7"
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0"
	}
