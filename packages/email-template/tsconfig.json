{
	"extends": "@beatros/typescript-config/base.json",
	"compilerOptions": {
		"jsx": "react", // Use classic JSX transform
		"lib": ["dom", "ES2015"],
		"module": "ESNext",
		"target": "ES2020",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"types": ["node"]
	},
	"exclude": ["node_modules", "dist"],
	"include": ["src"]
}
