{
	"name": "@beatros/user_service",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"prisma:migrate": "prisma migrate dev",
		"prisma:generate": "prisma generate",
		"prisma:reset": "prisma migrate reset",
		"check-types": "tsc --noEmit",
		"lint": "eslint src/ --max-warnings 0",
		"postinstall": "prisma generate"
	},
	"dependencies": {
		"@prisma/client": "6.14.0",
		"cors": "^2.8.5",
		"express": "^5.1.0",
		"morgan": "^1.10.1",
		"tsx": "^4.20.4"
	},
	"devDependencies": {
		"@beatros/typescript-config": "workspace:*",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.3",
		"@types/morgan": "^1.9.10",
		"@types/node": "^20.19.11",
		"prisma": "6.14.0"
	}
}
